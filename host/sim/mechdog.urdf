<?xml version="1.0"?>
<!--
  Hiwonder MechDog URDF model for PyBullet simulation.

  Dimensions from Hiwonder product specifications:
  - Body: ~173mm x 73mm x 50mm (assembled ~155x150x155mm)
  - Weight: ~500g total
  - 8 coreless servos (2 per leg: hip pitch + knee pitch)
  - Servo range: approximately ±90°
  - HC-SR04 ultrasonic sensor mounted on front face
  - Leg segments: upper ~55mm, lower ~60mm

  Coordinate frame: X = forward, Y = left, Z = up
-->
<robot name="mechdog">

  <!-- ============== BODY ============== -->
  <link name="body">
    <inertial>
      <mass value="0.35"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0003" ixy="0" ixz="0" iyy="0.0006" iyz="0" izz="0.0006"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.173 0.073 0.050"/>
      </geometry>
      <material name="body_color">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.173 0.073 0.050"/>
      </geometry>
    </collision>
  </link>

  <!-- ============== ULTRASONIC SENSOR ============== -->
  <link name="ultrasonic">
    <inertial>
      <mass value="0.005"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.045 0.020 0.015"/>
      </geometry>
      <material name="sensor_color">
        <color rgba="0.7 0.7 0.7 1"/>
      </material>
    </visual>
  </link>

  <joint name="ultrasonic_mount" type="fixed">
    <parent link="body"/>
    <child link="ultrasonic"/>
    <origin xyz="0.095 0 0.010" rpy="0 0 0"/>
  </joint>

  <!-- ============== MACRO-LIKE LEG DEFINITIONS ============== -->
  <!-- Front-Left Leg -->
  <link name="fl_upper">
    <inertial>
      <mass value="0.02"/>
      <origin xyz="0 0 -0.0275"/>
      <inertia ixx="0.000005" ixy="0" ixz="0" iyy="0.000005" iyz="0" izz="0.000001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.0275"/>
      <geometry><cylinder radius="0.008" length="0.055"/></geometry>
      <material name="leg_color"><color rgba="0.3 0.3 0.3 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.0275"/>
      <geometry><cylinder radius="0.008" length="0.055"/></geometry>
    </collision>
  </link>

  <joint name="fl_hip" type="revolute">
    <parent link="body"/>
    <child link="fl_upper"/>
    <origin xyz="0.065 0.040 -0.025" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="1.0" velocity="5.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <link name="fl_lower">
    <inertial>
      <mass value="0.02"/>
      <origin xyz="0 0 -0.030"/>
      <inertia ixx="0.000005" ixy="0" ixz="0" iyy="0.000005" iyz="0" izz="0.000001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.030"/>
      <geometry><cylinder radius="0.006" length="0.060"/></geometry>
      <material name="leg_color"><color rgba="0.3 0.3 0.3 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.030"/>
      <geometry><cylinder radius="0.006" length="0.060"/></geometry>
    </collision>
  </link>

  <joint name="fl_knee" type="revolute">
    <parent link="fl_upper"/>
    <child link="fl_lower"/>
    <origin xyz="0 0 -0.055" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="1.0" velocity="5.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <link name="fl_foot">
    <inertial>
      <mass value="0.005"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0000001" ixy="0" ixz="0" iyy="0.0000001" iyz="0" izz="0.0000001"/>
    </inertial>
    <visual>
      <geometry><sphere radius="0.008"/></geometry>
      <material name="foot_color"><color rgba="0.6 0.6 0.6 1"/></material>
    </visual>
    <collision>
      <geometry><sphere radius="0.008"/></geometry>
    </collision>
    <contact>
      <lateral_friction value="1.0"/>
      <rolling_friction value="0.01"/>
    </contact>
  </link>

  <joint name="fl_ankle" type="fixed">
    <parent link="fl_lower"/>
    <child link="fl_foot"/>
    <origin xyz="0 0 -0.060" rpy="0 0 0"/>
  </joint>

  <!-- Front-Right Leg -->
  <link name="fr_upper">
    <inertial>
      <mass value="0.02"/>
      <origin xyz="0 0 -0.0275"/>
      <inertia ixx="0.000005" ixy="0" ixz="0" iyy="0.000005" iyz="0" izz="0.000001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.0275"/>
      <geometry><cylinder radius="0.008" length="0.055"/></geometry>
      <material name="leg_color"><color rgba="0.3 0.3 0.3 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.0275"/>
      <geometry><cylinder radius="0.008" length="0.055"/></geometry>
    </collision>
  </link>

  <joint name="fr_hip" type="revolute">
    <parent link="body"/>
    <child link="fr_upper"/>
    <origin xyz="0.065 -0.040 -0.025" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="1.0" velocity="5.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <link name="fr_lower">
    <inertial>
      <mass value="0.02"/>
      <origin xyz="0 0 -0.030"/>
      <inertia ixx="0.000005" ixy="0" ixz="0" iyy="0.000005" iyz="0" izz="0.000001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.030"/>
      <geometry><cylinder radius="0.006" length="0.060"/></geometry>
      <material name="leg_color"><color rgba="0.3 0.3 0.3 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.030"/>
      <geometry><cylinder radius="0.006" length="0.060"/></geometry>
    </collision>
  </link>

  <joint name="fr_knee" type="revolute">
    <parent link="fr_upper"/>
    <child link="fr_lower"/>
    <origin xyz="0 0 -0.055" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="1.0" velocity="5.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <link name="fr_foot">
    <inertial>
      <mass value="0.005"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0000001" ixy="0" ixz="0" iyy="0.0000001" iyz="0" izz="0.0000001"/>
    </inertial>
    <visual>
      <geometry><sphere radius="0.008"/></geometry>
      <material name="foot_color"><color rgba="0.6 0.6 0.6 1"/></material>
    </visual>
    <collision>
      <geometry><sphere radius="0.008"/></geometry>
    </collision>
  </link>

  <joint name="fr_ankle" type="fixed">
    <parent link="fr_lower"/>
    <child link="fr_foot"/>
    <origin xyz="0 0 -0.060" rpy="0 0 0"/>
  </joint>

  <!-- Rear-Left Leg -->
  <link name="rl_upper">
    <inertial>
      <mass value="0.02"/>
      <origin xyz="0 0 -0.0275"/>
      <inertia ixx="0.000005" ixy="0" ixz="0" iyy="0.000005" iyz="0" izz="0.000001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.0275"/>
      <geometry><cylinder radius="0.008" length="0.055"/></geometry>
      <material name="leg_color"><color rgba="0.3 0.3 0.3 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.0275"/>
      <geometry><cylinder radius="0.008" length="0.055"/></geometry>
    </collision>
  </link>

  <joint name="rl_hip" type="revolute">
    <parent link="body"/>
    <child link="rl_upper"/>
    <origin xyz="-0.065 0.040 -0.025" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="1.0" velocity="5.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <link name="rl_lower">
    <inertial>
      <mass value="0.02"/>
      <origin xyz="0 0 -0.030"/>
      <inertia ixx="0.000005" ixy="0" ixz="0" iyy="0.000005" iyz="0" izz="0.000001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.030"/>
      <geometry><cylinder radius="0.006" length="0.060"/></geometry>
      <material name="leg_color"><color rgba="0.3 0.3 0.3 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.030"/>
      <geometry><cylinder radius="0.006" length="0.060"/></geometry>
    </collision>
  </link>

  <joint name="rl_knee" type="revolute">
    <parent link="rl_upper"/>
    <child link="rl_lower"/>
    <origin xyz="0 0 -0.055" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="1.0" velocity="5.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <link name="rl_foot">
    <inertial>
      <mass value="0.005"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0000001" ixy="0" ixz="0" iyy="0.0000001" iyz="0" izz="0.0000001"/>
    </inertial>
    <visual>
      <geometry><sphere radius="0.008"/></geometry>
      <material name="foot_color"><color rgba="0.6 0.6 0.6 1"/></material>
    </visual>
    <collision>
      <geometry><sphere radius="0.008"/></geometry>
    </collision>
  </link>

  <joint name="rl_ankle" type="fixed">
    <parent link="rl_lower"/>
    <child link="rl_foot"/>
    <origin xyz="0 0 -0.060" rpy="0 0 0"/>
  </joint>

  <!-- Rear-Right Leg -->
  <link name="rr_upper">
    <inertial>
      <mass value="0.02"/>
      <origin xyz="0 0 -0.0275"/>
      <inertia ixx="0.000005" ixy="0" ixz="0" iyy="0.000005" iyz="0" izz="0.000001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.0275"/>
      <geometry><cylinder radius="0.008" length="0.055"/></geometry>
      <material name="leg_color"><color rgba="0.3 0.3 0.3 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.0275"/>
      <geometry><cylinder radius="0.008" length="0.055"/></geometry>
    </collision>
  </link>

  <joint name="rr_hip" type="revolute">
    <parent link="body"/>
    <child link="rr_upper"/>
    <origin xyz="-0.065 -0.040 -0.025" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="1.0" velocity="5.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <link name="rr_lower">
    <inertial>
      <mass value="0.02"/>
      <origin xyz="0 0 -0.030"/>
      <inertia ixx="0.000005" ixy="0" ixz="0" iyy="0.000005" iyz="0" izz="0.000001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.030"/>
      <geometry><cylinder radius="0.006" length="0.060"/></geometry>
      <material name="leg_color"><color rgba="0.3 0.3 0.3 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.030"/>
      <geometry><cylinder radius="0.006" length="0.060"/></geometry>
    </collision>
  </link>

  <joint name="rr_knee" type="revolute">
    <parent link="rr_upper"/>
    <child link="rr_lower"/>
    <origin xyz="0 0 -0.055" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="1.0" velocity="5.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <link name="rr_foot">
    <inertial>
      <mass value="0.005"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0000001" ixy="0" ixz="0" iyy="0.0000001" iyz="0" izz="0.0000001"/>
    </inertial>
    <visual>
      <geometry><sphere radius="0.008"/></geometry>
      <material name="foot_color"><color rgba="0.6 0.6 0.6 1"/></material>
    </visual>
    <collision>
      <geometry><sphere radius="0.008"/></geometry>
    </collision>
  </link>

  <joint name="rr_ankle" type="fixed">
    <parent link="rr_lower"/>
    <child link="rr_foot"/>
    <origin xyz="0 0 -0.060" rpy="0 0 0"/>
  </joint>

</robot>
